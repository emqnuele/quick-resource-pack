{
    "schemaVersion": 1,
    "id": "quick-resource-pack",
    "version": "${version}",
    "name": "Quick Resource Pack",
    "description": "Quickly toggle a specific resource pack with a keybind.",
    "authors": [
        "emqnuele"
    ],
    "contact": {
        "homepage": "https://emqnueleelefaraci.com/",
        "sources": "https://github.com/emqnuele/quick-resource-pack"
    },
    "license": "MIT",
    "icon": "icon.png",
    "environment": "*",
    "entrypoints": {
        "client": [
            "com.emqnuele.quickresourcepack.QuickResourcePackMod"
        ],
        "modmenu": [
            "com.emqnuele.quickresourcepack.integration.ModMenuIntegration"
        ]
    },
    "mixins": [
        "quickresourcepack.mixins.json"
    ],
    "depends": {
        "fabricloader": ">=${loader_version}",
        "minecraft": ">=26.1 <26.2",
        "java": ">=25",
        "fabric-api": "*",
        "cloth-config": "*"
    },
    "suggests": {
        "modmenu": "*"
    }
}